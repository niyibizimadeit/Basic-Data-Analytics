


import torch

# creating a tensor for house sizes (in 1000 sq ft)
x = torch.tensor([1.0, 2.0, 3.0])

#creating tensors for weight and bias
w = torch.tensor(2.0, requires_grad=True)
b = torch.tensor(0.5, requires_grad=True)

# The function that generates the output
y = w * x + b

#printing x, w, b, and y
print("Input(x): ", x)
print("Weight(w)", w.item())
print("Bias(b)", b.item())
print("Output(y)", y)


