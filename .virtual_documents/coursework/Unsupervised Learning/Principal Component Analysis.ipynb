from sklearn.decomposition import PCA
from sklearn.datasets import load_iris
import numpy as np
import matplotlib.pyplot as plt

#loading the samole dataset
iris = load_iris()
X = iris.data


#Fit PCA without limits
pca = PCA().fit(X)

#Explained variance ratio
print("Explained variance ratio", pca.explained_variance_ratio_)

#Cumulative variance
cum_var = np.cumsum(pca.explained_variance_ratio_)
print("Cumulative explained variance", cum_var)

# Plot cumulative variance
plt.plot(range(1, len(cum_var)+1), cum_var, marker='o')
plt.xlabel("Number of Components")
plt.ylabel("Cumulative Explained Variance")
plt.title("PCA - Explained Variance")
plt.grid(True)
plt.show()





from sklearn.model_selection import train_test_split
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import accuracy_score, classification_report
#reduce to 2 principal components

y = iris.target
pca = PCA(n_components=2)
X_pca = pca.fit_transform(X)

#split the test and training set
X_train, X_test, y_train, y_test = train_test_split(X_pca, y, test_size=0.20, random_state=42, stratify=y)

#Training the logistic regression model
model = LogisticRegression(max_iter=1000)
model.fit(X_train, y_train)

y_pred = model.predict(X_test)

print("Accuracy score: ", accuracy_score(y_test, y_pred))
print("Classification Report: ", classification_report(y_test, y_pred))











